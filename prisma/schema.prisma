generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  avatar        String?
  password      String?
  plan          String    @default("free")
  credits       Int       @default(3)
  creditsResetAt DateTime?
  phone         String?
  bio           String?
  company       String?
  location      String?
  preferences   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @updatedAt

  accounts Account[]
  sessions Session[]
  sites    Site[]
}

model Site {
  id             String   @id @default(cuid())
  userId         String?
  placeId        String?
  subdomain      String   @unique
  customDomain   String?
  parentId       String?
  status         String   @default("draft")
  theme          String   @default("modern-light")
  data           Json     @default("{}")
  analytics      Json     @default("{}")
  pages          Json     @default("[]")
  sectionOrder   Json?
  sections       Json?
  fontPairing    String?
  customColors   Json?
  stickyHeader   Boolean?
  darkMode       Boolean?
  bgPattern      String?
  entranceAnim   String?
  favicon        String?
  logo           String?
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User?  @relation(fields: [userId], references: [id])
  parent Site?  @relation("SiteHierarchy", fields: [parentId], references: [id])
  children Site[] @relation("SiteHierarchy")

  @@index([userId])
  @@index([subdomain])
  @@index([parentId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ScrapeCache {
  placeId   String   @id
  rawData   Json
  scrapedAt DateTime @default(now())
}
